APP_NAME="Laravel Tenant Kit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://laravel-tenant-kit.test
APP_PORT_ALT=
CENTRAL_DOMAIN=laravel-tenant-kit.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_AVAILABLE_LOCALES=en,ar

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — MySQL (default) or PostgreSQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel_tenant_kit
DB_USERNAME=root
DB_PASSWORD=

# PostgreSQL alternative (Stancl supports database-per-tenant on pgsql):
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel_tenant_kit
# DB_USERNAME=laravel
# DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Redis — recommended for production / Docker (see .env.docker)
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# TENANCY_USE_REDIS_BOOTSTRAPPER=true

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

TENANCY_USE_REDIS_BOOTSTRAPPER=false

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe (optional — enable workspace billing)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
CASHIER_CURRENCY=usd
CASHIER_LOGGER=stack

# Usage-based billing (v1.3 — local DB tracking; optional Stripe meter sync)
USAGE_BILLING_ENABLED=true
USAGE_SYNC_TO_STRIPE=false
STRIPE_METER_API_CALLS=api_calls
STRIPE_METER_TEAM_SEATS=team_seats

# OAuth (optional — enables Google / GitHub buttons on login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"

# Sanctum API tokens (see docs/api.md)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,${CENTRAL_DOMAIN}
API_AUTH_RATE_LIMIT=5
API_AUTH_RATE_DECAY=1

# api-operator CLI (optional — see docs/api-operator.md)
TENANT_KIT_API_TOKEN=

# In-app API Operator chat widget (requires api-operator serve)
API_OPERATOR_ENABLED=false
API_OPERATOR_URL=http://127.0.0.1:8100
API_OPERATOR_ADAPTER_PATH=integrations/api-operator/adapter.yaml
API_OPERATOR_TENANT_KIT_BASE_URL=
API_OPERATOR_CONNECT_HOST=
API_OPERATOR_TIMEOUT=60
